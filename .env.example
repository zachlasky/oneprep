# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored — never commit real keys.

# Anthropic API key for briefing generation (server-side only).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- GitHub (data source) ---
# Optional for PUBLIC data — raises the rate limit when present.
# Will give access to private repos if the token has those scopes.
# Recommend using fine-grained tokens vs classic tokens.
# For public repos no scopes are required. Create at https://github.com/settings/tokens
GITHUB_TOKEN=

# --- Jira (data source) — these are all YOUR OWN credentials, set once ---
# They authenticate the app AS YOU. The teammate you're prepping for is chosen
# per-request in the form (their Atlassian account ID) — NOT configured here.
#
# JIRA_SITE       Your company's shared Atlassian site (same for everyone in the
#                 org — not teammate-specific). e.g. acme.atlassian.net
# JIRA_EMAIL      YOUR email — the account the API token belongs to. NOT the
#                 teammate's email; you authenticate as yourself and look the
#                 teammate up by their account ID.
# JIRA_API_TOKEN  Your token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_SITE=your-site.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=
